<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ============ WINGS (4, translucent cyan, rooted at the thorax) ======= -->

    <!-- Upper-left forewing -->
    <group android:pivotX="54" android:pivotY="50" android:rotation="-152">
        <path android:pathData="M67,50 m-13,0 a13,4.5 0 1,0 26,0 a13,4.5 0 1,0 -26,0"
            android:fillColor="#42B8F5E6"
            android:strokeColor="#CC9DFCE8" android:strokeWidth="1" />
        <path android:pathData="M55,50 L79,50"
            android:strokeColor="#888EEAD4" android:strokeWidth="0.7" />
    </group>

    <!-- Upper-right forewing -->
    <group android:pivotX="54" android:pivotY="50" android:rotation="-28">
        <path android:pathData="M67,50 m-13,0 a13,4.5 0 1,0 26,0 a13,4.5 0 1,0 -26,0"
            android:fillColor="#42B8F5E6"
            android:strokeColor="#CC9DFCE8" android:strokeWidth="1" />
        <path android:pathData="M55,50 L79,50"
            android:strokeColor="#888EEAD4" android:strokeWidth="0.7" />
    </group>

    <!-- Lower-left hindwing -->
    <group android:pivotX="54" android:pivotY="54" android:rotation="154">
        <path android:pathData="M67.5,54 m-13.5,0 a13.5,5 0 1,0 27,0 a13.5,5 0 1,0 -27,0"
            android:fillColor="#3AA6F0DE"
            android:strokeColor="#BB9DFCE8" android:strokeWidth="1" />
        <path android:pathData="M55,54 L80,54"
            android:strokeColor="#888EEAD4" android:strokeWidth="0.7" />
    </group>

    <!-- Lower-right hindwing -->
    <group android:pivotX="54" android:pivotY="54" android:rotation="26">
        <path android:pathData="M67.5,54 m-13.5,0 a13.5,5 0 1,0 27,0 a13.5,5 0 1,0 -27,0"
            android:fillColor="#3AA6F0DE"
            android:strokeColor="#BB9DFCE8" android:strokeWidth="1" />
        <path android:pathData="M55,54 L80,54"
            android:strokeColor="#888EEAD4" android:strokeWidth="0.7" />
    </group>

    <!-- ============ BODY ==================================================== -->

    <!-- Abdomen: tapering spindle with a vertical cyan gradient -->
    <path android:pathData="M51.8,54 Q54,51.5 56.2,54 L54.7,82 Q54,86 53.3,82 L51.8,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="52"
                android:endX="54" android:endY="86">
                <item android:offset="0" android:color="#FF9DFCE8" />
                <item android:offset="1" android:color="#FF22D3A6" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Abdomen segment lines -->
    <path android:pathData="M52.4,60 L55.6,60" android:strokeColor="#800B2533" android:strokeWidth="0.9" />
    <path android:pathData="M52.6,66 L55.4,66" android:strokeColor="#800B2533" android:strokeWidth="0.9" />
    <path android:pathData="M52.8,72 L55.2,72" android:strokeColor="#800B2533" android:strokeWidth="0.9" />
    <path android:pathData="M53.1,78 L54.9,78" android:strokeColor="#800B2533" android:strokeWidth="0.9" />

    <!-- Tail tip accent (coral) -->
    <path android:pathData="M54,85 m-1.6,0 a1.6,1.6 0 1,0 3.2,0 a1.6,1.6 0 1,0 -3.2,0"
        android:fillColor="#FFAE86" />

    <!-- Thorax -->
    <path android:pathData="M54,49 m-3.6,0 a3.6,4.6 0 1,0 7.2,0 a3.6,4.6 0 1,0 -7.2,0"
        android:fillColor="#FFB8F5E6" />

    <!-- Head + two large compound eyes -->
    <path android:pathData="M52,40 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0"
        android:fillColor="#FF5EEAD4" />
    <path android:pathData="M56,40 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0"
        android:fillColor="#FF5EEAD4" />
    <path android:pathData="M52,39 m-1,0 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0"
        android:fillColor="#FF9DFCE8" />
    <path android:pathData="M56,39 m-1,0 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0"
        android:fillColor="#FF9DFCE8" />
</vector>
