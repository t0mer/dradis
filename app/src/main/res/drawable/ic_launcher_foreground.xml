<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Crosshair -->
    <path android:pathData="M54,23 L54,85"
        android:strokeColor="#36F1A0" android:strokeAlpha="0.16" android:strokeWidth="1" />
    <path android:pathData="M23,54 L85,54"
        android:strokeColor="#36F1A0" android:strokeAlpha="0.16" android:strokeWidth="1" />

    <!-- Concentric radar rings -->
    <path android:pathData="M54,54 m-31,0 a31,31 0 1,0 62,0 a31,31 0 1,0 -62,0"
        android:fillColor="#00000000"
        android:strokeColor="#36F1A0" android:strokeAlpha="0.32" android:strokeWidth="1.6" />
    <path android:pathData="M54,54 m-22,0 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0"
        android:fillColor="#00000000"
        android:strokeColor="#5EEAD4" android:strokeAlpha="0.5" android:strokeWidth="1.6" />
    <path android:pathData="M54,54 m-13,0 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0"
        android:fillColor="#00000000"
        android:strokeColor="#5EEAD4" android:strokeAlpha="0.72" android:strokeWidth="1.6" />

    <!-- Sweep wedge with fading gradient -->
    <path android:pathData="M54,54 L54,23 A31,31 0 0,1 80.85,38.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="54"
                android:endX="74" android:endY="32">
                <item android:offset="0" android:color="#A636F1A0" />
                <item android:offset="1" android:color="#0036F1A0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bright leading edge of the sweep -->
    <path android:pathData="M54,54 L54,23"
        android:strokeColor="#9DFCE8" android:strokeWidth="1.8" android:strokeLineCap="round" />

    <!-- Contact blip: coral halo + dot -->
    <path android:pathData="M41.4,72 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0"
        android:fillColor="#FF8A5C" android:fillAlpha="0.30" />
    <path android:pathData="M41.4,72 m-2.6,0 a2.6,2.6 0 1,0 5.2,0 a2.6,2.6 0 1,0 -5.2,0"
        android:fillColor="#FFAE86" />

    <!-- Centre node -->
    <path android:pathData="M54,54 m-2.4,0 a2.4,2.4 0 1,0 4.8,0 a2.4,2.4 0 1,0 -4.8,0"
        android:fillColor="#9DFCE8" />
</vector>
